{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:env-secrets" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:quick-fix-blocker" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:prompt-injection" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [{ "type": "command", "command": "GUARD:test-reminder" }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "GUARD:session-file-tracker" }]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [{ "type": "command", "command": ".claude/hooks/session-start.sh" }]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-compact.sh" }]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "{{AGENT_NAMES}}",
        "hooks": [{ "type": "command", "command": ".claude/hooks/subagent-start.sh" }]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": ".claude/hooks/post-failure.sh" }]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [{ "type": "command", "command": ".claude/hooks/task-completed.sh" }]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [{ "type": "command", "command": ".claude/hooks/teammate-idle.sh" }]
      }
    ]
  }
}
