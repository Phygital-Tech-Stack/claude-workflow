{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:env-secrets" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:quick-fix-blocker" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:prompt-injection" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:critical-file" }]
      },
      {
        "matcher": "Write",
        "hooks": [{ "type": "prompt", "prompt": "GUARD:scope-estimator" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:test-reminder" }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "GUARD:session-file-tracker" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:check-file-size" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "GUARD:co-authored-by" }]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          { "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/session-start.py" },
          { "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/mcp-security-scan.py" }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [{ "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/pre-compact.py" }]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "{{AGENT_NAMES}}",
        "hooks": [{ "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/subagent-start.py" }]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/post-failure.py" }]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [{ "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/task-completed.py" }]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [{ "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/teammate-idle.py" }]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/prompt-submit.py" },
          { "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/context-check.py" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [{ "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/subagent-stop.py" }]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [{ "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pyrun .claude/hooks/session-end.py" }]
      }
    ]
  }
}
