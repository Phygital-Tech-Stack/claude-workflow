{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:check-layer-imports" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pyrun .claude/hooks/dart_format.py", "timeout": 30 }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pyrun .claude/hooks/check_print.py", "timeout": 10 }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pyrun .claude/hooks/dart_analyze.py", "timeout": 30 }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pyrun .claude/hooks/check_file_size.py", "timeout": 10 }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pyrun .claude/hooks/check_deprecated.py", "timeout": 10 }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pyrun .claude/hooks/check_imports.py", "timeout": 10 }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pyrun .claude/hooks/check_nesting.py", "timeout": 10 }]
      }
    ]
  }
}
