{
  "mcpServers": {
    "pharos": {
      "type": "http",
      "url": "https://mcp.phygital-tech.ai/pharos/mcp",
      "headers": {
        "Authorization": "Bearer {{PHAROS_TOKEN}}"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{GITHUB_TOKEN}}"
      }
    }
  }
}
