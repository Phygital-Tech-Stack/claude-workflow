{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": ".claude/hooks/tdd-guard.sh" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "GUARD:design-doc-guard" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:file-size-limits" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:ts-ignore-blocker" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:any-type-blocker" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:naming-detector" }]
      }
    ]
  }
}
