{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/tdd-guard.sh" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "GUARD:design-doc-guard" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:file-size-limits" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:ts-ignore-blocker" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:any-type-blocker" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:naming-detector" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "GUARD:check-layer-imports" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/prettier_format.sh", "timeout": 15 }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/eslint_check.sh", "timeout": 30 }]
      }
    ]
  }
}
